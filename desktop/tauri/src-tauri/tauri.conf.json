{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multi Account AI Control",
  "version": "0.1.0",
  "identifier": "com.multiaccountaicontrol.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev",
    "beforeBuildCommand": "npm --prefix ../.. run desktop:prepare-runtime",
    "devUrl": "http://localhost:3000",
    "frontendDist": "launcher-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Multi Account AI Control",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "msi",
      "nsis"
    ],
    "resources": [
      "next-runtime"
    ]
  }
}
