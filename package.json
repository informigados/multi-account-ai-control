{
  "name": "multi-account-ai-control",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start",
    "lint": "npm --prefix apps/web run lint",
    "typecheck": "npm --prefix apps/web run typecheck",
    "test:critical": "node scripts/run-critical-tests.mjs",
    "desktop:preflight": "node scripts/desktop-preflight.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin.ts"
  },
  "devDependencies": {
    "prisma": "^6.8.0",
    "tsx": "^4.19.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
